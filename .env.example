# Copy to .env and fill in. .env is gitignored — never commit real keys.
#
# Local values come from `supabase start`, which prints them on startup
# (`supabase status` reprints them). They are the same on every machine.
# Production values come from the Supabase dashboard: Project Settings → API keys.

# Sent to the browser. Public by design — RLS is what protects the data.
PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Server-side only. Bypasses RLS entirely. Never prefix this PUBLIC_, never
# commit it, and never add it to a client-scoped Vercel environment variable.
SUPABASE_SECRET_KEY=""
